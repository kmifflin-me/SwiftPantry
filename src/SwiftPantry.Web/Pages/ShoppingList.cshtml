@page
@model SwiftPantry.Web.Pages.ShoppingListModel
@using SwiftPantry.Web.Models
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Shopping List";

    var unpurchased = Model.Items.Where(i => !i.IsPurchased).ToList();
    var purchased   = Model.Items.Where(i =>  i.IsPurchased).ToList();
}

@* Anti-forgery token for AJAX mark-purchased calls *@
<input type="hidden" id="af-token" name="__RequestVerificationToken"
       value="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">Shopping List</h2>
        </div>
        <div class="col-auto text-muted mt-1">
            <small>@unpurchased.Count remaining · @purchased.Count purchased</small>
        </div>
    </div>

    <!-- Add Item Form -->
    <div class="card mb-4">
        <div class="card-header">Add Item</div>
        <div class="card-body">
            <form method="post" asp-page-handler="Add">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Name</label>
                        <input class="form-control @(ViewData.ModelState["NewItem.Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               name="NewItem.Name"
                               maxlength="200" required
                               placeholder="e.g. Eggs"
                               value="@Model.NewItem.Name"
                               data-testid="add-shopping-item-name" />
                        <div class="invalid-feedback">
                            @(ViewData.ModelState["NewItem.Name"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Quantity</label>
                        <input class="form-control @(ViewData.ModelState["NewItem.Quantity"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               name="NewItem.Quantity"
                               maxlength="100" required
                               placeholder="e.g. 1 dozen"
                               value="@Model.NewItem.Quantity"
                               data-testid="add-shopping-item-quantity" />
                        <div class="invalid-feedback">
                            @(ViewData.ModelState["NewItem.Quantity"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Category</label>
                        <select class="form-select @(ViewData.ModelState["NewItem.Category"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                name="NewItem.Category"
                                required
                                data-testid="add-shopping-item-category">
                            <option value="" disabled selected="@(string.IsNullOrEmpty(Model.NewItem.Category))">— Select —</option>
                            @foreach (var cat in CategoryOrder.Ordered)
                            {
                                <option value="@cat" selected="@(Model.NewItem.Category == cat)">
                                    @CategoryOrder.DisplayNames[cat]
                                </option>
                            }
                        </select>
                        <div class="invalid-feedback">
                            @(ViewData.ModelState["NewItem.Category"]?.Errors.FirstOrDefault()?.ErrorMessage)
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" type="submit"
                                data-testid="add-shopping-item-submit">Add Item</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <!-- Empty State -->
        <div class="card">
            <div class="card-body text-center py-5 text-muted" data-testid="shopping-empty-state">
                <p class="mb-2">Your shopping list is empty.</p>
                <p class="mb-0"><small>Add items above, or visit a recipe and use "Add Missing to Shopping List".</small></p>
            </div>
        </div>
    }
    else
    {
        <!-- Unpurchased Items -->
        @if (unpurchased.Any())
        {
            <div class="card mb-3" data-testid="shopping-list-unpurchased">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>To Buy</span>
                    <small class="text-muted">@unpurchased.Count item@(unpurchased.Count == 1 ? "" : "s")</small>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var item in unpurchased)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center"
                            id="shopping-item-@item.Id"
                            data-testid="shopping-item-@item.Id">
                            <div class="d-flex align-items-center gap-3">
                                <input type="checkbox"
                                       class="form-check-input shopping-check"
                                       data-item-id="@item.Id"
                                       data-testid="shopping-item-check-@item.Id" />
                                <div>
                                    <span class="item-name fw-semibold">@item.Name</span>
                                    <span class="text-muted ms-2">@item.Quantity</span>
                                    <span class="badge bg-secondary ms-1">@CategoryOrder.DisplayNames.GetValueOrDefault(item.Category, item.Category)</span>
                                </div>
                            </div>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id"
                                  class="d-inline">
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Remove this item?')"
                                        data-testid="shopping-item-delete-@item.Id">
                                    Delete
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Purchased Items -->
        @if (purchased.Any())
        {
            <div class="card mb-3" data-testid="shopping-list-purchased">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Purchased</span>
                    <form method="post" asp-page-handler="ClearPurchased" class="d-inline">
                        <button type="submit"
                                class="btn btn-sm btn-outline-secondary"
                                onclick="return confirm('Clear all purchased items?')"
                                data-testid="clear-checked-button">
                            Clear Purchased
                        </button>
                    </form>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var item in purchased)
                    {
                        <li class="list-group-item shopping-item-purchased d-flex justify-content-between align-items-center"
                            id="shopping-item-@item.Id"
                            data-testid="shopping-item-@item.Id">
                            <div class="d-flex align-items-center gap-3">
                                <input type="checkbox"
                                       class="form-check-input shopping-check"
                                       checked
                                       data-item-id="@item.Id"
                                       data-testid="shopping-item-check-@item.Id" />
                                <div>
                                    <span class="item-name fw-semibold">@item.Name</span>
                                    <span class="text-muted ms-2">@item.Quantity</span>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <form method="post" asp-page-handler="MoveToPantry" asp-route-id="@item.Id"
                                      class="d-inline">
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-success"
                                            data-testid="move-to-pantry-@item.Id">
                                        → Pantry
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id"
                                      class="d-inline">
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Remove this item?')"
                                            data-testid="shopping-item-delete-@item.Id">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }
    }
</div>
