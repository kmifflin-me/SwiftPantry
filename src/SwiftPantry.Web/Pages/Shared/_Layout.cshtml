@inject SwiftPantry.Web.Services.IProfileService ProfileService
@{
    bool hideNavbar = ViewData["HideNavbar"] as bool? ?? false;
    bool profileExists = hideNavbar ? true : await ProfileService.ProfileExistsAsync();
    var currentPath = Context.Request.Path.Value ?? "";

    string NavClass(string path) =>
        currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SwiftPantry</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Apply saved theme before page renders to prevent flash of wrong theme
        (function () {
            var t = localStorage.getItem('sp-theme');
            if (t === 'dark') document.documentElement.setAttribute('data-bs-theme', 'dark');
        })();
    </script>
</head>
<body>
    @if (!hideNavbar && profileExists)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-brand fixed-top" data-testid="main-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/MealLog">SwiftPantry</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="@NavClass("/MealLog")" asp-page="/MealLog" data-testid="nav-meallog">Meal Log</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Recipes")" asp-page="/Recipes/Index" data-testid="nav-recipes">Recipes</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Pantry")" asp-page="/Pantry" data-testid="nav-pantry">Pantry</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/ShoppingList")" asp-page="/ShoppingList" data-testid="nav-shoppinglist">Shopping</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/SavedRecipes")" asp-page="/SavedRecipes" data-testid="nav-savedrecipes">Saved</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavClass("/Profile")" asp-page="/Profile/Index" data-testid="nav-profile">Profile</a>
                        </li>
                        <li class="nav-item ms-2 d-flex align-items-center">
                            <button class="btn-dark-toggle" id="darkModeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                                <svg id="darkModeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z"/>
                                </svg>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="@((!hideNavbar && profileExists) ? "main-content" : "")">
        @if (TempData["Success"] is string successMsg)
        {
            <div class="container-fluid px-0">
                <div class="alert alert-success alert-dismissible fade show mb-0" role="alert">
                    @successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] is string errorMsg)
        {
            <div class="container-fluid px-0">
                <div class="alert alert-danger alert-dismissible fade show mb-0" role="alert">
                    @errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
