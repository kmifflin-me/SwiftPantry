@page
@model SwiftPantry.Web.Pages.Profile.SetupModel
@{
    ViewData["Title"] = "Profile Setup";
    ViewData["HideNavbar"] = true;
    Layout = "_Layout";
}

<div class="bg-light min-vh-100 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Set Up Your Health Profile</h4>
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <div asp-validation-summary="None" class="text-danger mb-3"></div>

                            @* Age + Sex *@
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="Age">Age</label>
                                    <input id="Age" name="Age" type="number"
                                           class="form-control @(ViewData.ModelState["Age"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                           min="10" max="120" required placeholder="e.g. 28"
                                           value="@Model.Age"
                                           data-testid="age-input" />
                                    <div class="invalid-feedback">@Html.ValidationMessage("Age")</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="Sex">Sex</label>
                                    <select id="Sex" name="Sex"
                                            class="form-select @(ViewData.ModelState["Sex"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                            required
                                            data-testid="sex-select">
                                        <option value="" disabled selected="@(string.IsNullOrEmpty(Model.Sex))">— Select —</option>
                                        <option value="Male" selected="@(Model.Sex == "Male")">Male</option>
                                        <option value="Female" selected="@(Model.Sex == "Female")">Female</option>
                                    </select>
                                    <div class="invalid-feedback">@Html.ValidationMessage("Sex")</div>
                                </div>
                            </div>

                            @* Height *@
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="Height">Height</label>
                                    <input id="Height" name="Height" type="number"
                                           class="form-control @(ViewData.ModelState["Height"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                           step="0.1" required placeholder="e.g. 68"
                                           value="@Model.Height"
                                           data-testid="height-input" />
                                    <div class="invalid-feedback">@Html.ValidationMessage("Height")</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="HeightUnit">Unit</label>
                                    <select id="HeightUnit" name="HeightUnit"
                                            class="form-select @(ViewData.ModelState["HeightUnit"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                            required
                                            data-testid="height-unit-select">
                                        <option value="in" selected="@(Model.HeightUnit == "in" || string.IsNullOrEmpty(Model.HeightUnit))">Inches (in)</option>
                                        <option value="cm" selected="@(Model.HeightUnit == "cm")">Centimeters (cm)</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a unit.</div>
                                </div>
                            </div>

                            @* Weight *@
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="Weight">Weight</label>
                                    <input id="Weight" name="Weight" type="number"
                                           class="form-control @(ViewData.ModelState["Weight"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                           step="0.1" required placeholder="e.g. 175"
                                           value="@Model.Weight"
                                           data-testid="weight-input" />
                                    <div class="invalid-feedback">@Html.ValidationMessage("Weight")</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="WeightUnit">Unit</label>
                                    <select id="WeightUnit" name="WeightUnit"
                                            class="form-select @(ViewData.ModelState["WeightUnit"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                            required
                                            data-testid="weight-unit-select">
                                        <option value="lbs" selected="@(Model.WeightUnit == "lbs" || string.IsNullOrEmpty(Model.WeightUnit))">Pounds (lbs)</option>
                                        <option value="kg" selected="@(Model.WeightUnit == "kg")">Kilograms (kg)</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a unit.</div>
                                </div>
                            </div>

                            @* Activity Level *@
                            <div class="row g-3 mb-3">
                                <div class="col-12">
                                    <label class="form-label" for="ActivityLevel">Activity Level</label>
                                    <select id="ActivityLevel" name="ActivityLevel"
                                            class="form-select @(ViewData.ModelState["ActivityLevel"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                            required
                                            data-testid="activity-level-select">
                                        <option value="" disabled selected="@(string.IsNullOrEmpty(Model.ActivityLevel))">— Select —</option>
                                        <option value="Sedentary"        selected="@(Model.ActivityLevel == "Sedentary")">Sedentary (little or no exercise)</option>
                                        <option value="LightlyActive"    selected="@(Model.ActivityLevel == "LightlyActive")">Lightly Active (1–3 days/week)</option>
                                        <option value="ModeratelyActive" selected="@(Model.ActivityLevel == "ModeratelyActive")">Moderately Active (3–5 days/week)</option>
                                        <option value="VeryActive"       selected="@(Model.ActivityLevel == "VeryActive")">Very Active (6–7 days/week)</option>
                                        <option value="ExtraActive"      selected="@(Model.ActivityLevel == "ExtraActive")">Extra Active (hard exercise + physical job)</option>
                                    </select>
                                    <div class="invalid-feedback">@Html.ValidationMessage("ActivityLevel")</div>
                                </div>
                            </div>

                            @* Goal *@
                            <div class="row g-3 mb-4">
                                <div class="col-12">
                                    <label class="form-label" for="Goal">Your Goal</label>
                                    <select id="Goal" name="Goal"
                                            class="form-select @(ViewData.ModelState["Goal"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                            required
                                            data-testid="goal-select">
                                        <option value="" disabled selected="@(string.IsNullOrEmpty(Model.Goal))">— Select —</option>
                                        <option value="LoseWeight"  selected="@(Model.Goal == "LoseWeight")">Lose Weight (−500 kcal/day)</option>
                                        <option value="Maintain"    selected="@(Model.Goal == "Maintain")">Maintain (TDEE)</option>
                                        <option value="GainWeight"  selected="@(Model.Goal == "GainWeight")">Gain Weight (+300 kcal/day)</option>
                                    </select>
                                    <div class="invalid-feedback">@Html.ValidationMessage("Goal")</div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 btn-lg"
                                    data-testid="save-profile-button">
                                Calculate &amp; Save Profile
                            </button>
                        </form>
                    </div>
                    <div class="card-footer text-muted text-center small">
                        You can edit this at any time from the Profile page.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
